# Generate unique local values before first boot. Never commit .env.
POSTGRES_DB=vibebase
POSTGRES_USER=vibebase
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_PORT=5432
REDIS_PASSWORD=replace-with-a-different-long-random-password
REDIS_PORT=6379
VIBEBASE_PORT=3000

# Server-side only. Do not prefix with NEXT_PUBLIC_.
VIBEBASE_SESSION_SECRET=replace-with-at-least-32-random-characters
APPWRITE_ENDPOINT=http://host.docker.internal/v1
APPWRITE_PROJECT_ID=replace-after-appwrite-bootstrap
APPWRITE_API_KEY=replace-after-appwrite-bootstrap
APPWRITE_DATABASE_ID=replace-after-appwrite-bootstrap
DOKPLOY_ENDPOINT=http://host.docker.internal:3000/api
DOKPLOY_API_KEY=replace-after-dokploy-bootstrap
DOKPLOY_ENVIRONMENT_ID=replace-after-dokploy-bootstrap
DOKPLOY_SERVER_ID=optional-dokploy-server-id
